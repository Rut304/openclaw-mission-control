"use client";

import { useState, useEffect, useCallback, useRef } from "react";
import { Trophy, MessageSquare, Zap, Coffee, Users, Crown, ChevronDown, Search } from "lucide-react";

// ========== TYPES ==========

interface OfficeAgent {
  id: string;
  name: string;
  role: string;
  emoji: string;
  color: string;
  visualState: "working" | "idle" | "sleeping" | "collaborating" | "frustrated";
  currentTask: string | null;
  progressPct: number;
  lastMessage: string | null;
  lastMessageTime: string | null;
  score: number;
  revenue: number;
  streak: number;
  rank: number;
  title: string;
  trashTalkStyle: string;
  minutesSinceUpdate: number;
}

interface CommMessage {
  id: string;
  from: string;
  to: string;
  type: string;
  message: string;
  context?: string;
  timestamp: string;
}

interface Collaboration {
  agents: string[];
  topic: string;
}

interface OfficeData {
  agents: OfficeAgent[];
  comms: CommMessage[];
  leaderboard: OfficeAgent[];
  collaborations: Collaboration[];
  achievements: unknown[];
  updatedAt: string;
}

// ========== DESK LAYOUT ==========
// 3x3 grid of desks with an aisle in the middle
const DESK_POSITIONS: Record<string, { x: number; y: number; row: string }> = {
  rip:    { x: 1, y: 0, row: "exec" },
  rex:    { x: 2, y: 0, row: "exec" },
  red:    { x: 3, y: 0, row: "exec" },
  rio:    { x: 0, y: 1, row: "staff" },
  ria:    { x: 1, y: 1, row: "staff" },
  rea:    { x: 2, y: 1, row: "staff" },
  reg:    { x: 0, y: 2, row: "workers" },
  rak:    { x: 1, y: 2, row: "workers" },
  worker: { x: 2, y: 2, row: "workers" },
};

// ========== STATE ANIMATIONS ==========
const STATE_CONFIG = {
  working: {
    icon: "⌨️",
    animation: "animate-pulse",
    statusText: "Grinding",
    bgClass: "bg-green-500/20 border-green-500/40",
    glowClass: "shadow-[0_0_12px_rgba(34,197,94,0.4)]",
    dotColor: "bg-green-400",
  },
  idle: {
    icon: "💤",
    animation: "",
    statusText: "Chilling",
    bgClass: "bg-yellow-500/10 border-yellow-500/30",
    glowClass: "",
    dotColor: "bg-yellow-400",
  },
  sleeping: {
    icon: "😴",
    animation: "animate-bounce-slow",
    statusText: "Asleep",
    bgClass: "bg-zinc-500/10 border-zinc-500/30",
    glowClass: "",
    dotColor: "bg-zinc-500",
  },
  collaborating: {
    icon: "🤝",
    animation: "animate-pulse",
    statusText: "Collab",
    bgClass: "bg-purple-500/20 border-purple-500/40",
    glowClass: "shadow-[0_0_12px_rgba(168,85,247,0.4)]",
    dotColor: "bg-purple-400",
  },
  frustrated: {
    icon: "😤",
    animation: "animate-shake",
    statusText: "Blocked",
    bgClass: "bg-red-500/20 border-red-500/40",
    glowClass: "shadow-[0_0_12px_rgba(239,68,68,0.4)]",
    dotColor: "bg-red-400",
  },
};

// ========== MESSAGE TYPE STYLES ==========
const MSG_STYLES: Record<string, { color: string; label: string }> = {
  collaborate: { color: "text-purple-400", label: "🤝" },
  delegate: { color: "text-blue-400", label: "📋" },
  report: { color: "text-green-400", label: "📊" },
  banter: { color: "text-yellow-400", label: "🗣️" },
  taunt: { color: "text-red-400", label: "🔥" },
  celebrate: { color: "text-emerald-400", label: "🎉" },
  blocker: { color: "text-red-500", label: "🚫" },
  question: { color: "text-cyan-400", label: "❓" },
};

// ========== RANK BORDER COLORS ==========
const RANK_BORDERS: Record<number, string> = {
  1: "ring-2 ring-yellow-400/80 shadow-[0_0_16px_rgba(250,204,21,0.3)]",
  2: "ring-2 ring-zinc-300/60 shadow-[0_0_12px_rgba(161,161,170,0.25)]",
  3: "ring-2 ring-amber-600/60 shadow-[0_0_12px_rgba(217,119,6,0.25)]",
  4: "ring-1 ring-blue-400/40",
  5: "ring-1 ring-blue-400/30",
  6: "ring-1 ring-zinc-500/30",
  7: "ring-1 ring-zinc-500/20",
  8: "ring-1 ring-zinc-600/20",
  9: "ring-1 ring-zinc-700/20",
};

// ========== AGENT DESK COMPONENT ==========
function AgentDesk({
  agent,
  isSelected,
  onClick,
  showBubble,
}: {
  agent: OfficeAgent;
  isSelected: boolean;
  onClick: () => void;
  showBubble: boolean;
}) {
  const config = STATE_CONFIG[agent.visualState] || STATE_CONFIG.idle;
  const rankBorder = RANK_BORDERS[agent.rank] || "";
  const [bubbleVisible, setBubbleVisible] = useState(false);

  useEffect(() => {
    if (showBubble && agent.lastMessage) {
      setBubbleVisible(true);
      const timer = setTimeout(() => setBubbleVisible(false), 8000);
      return () => clearTimeout(timer);
    }
  }, [showBubble, agent.lastMessage]);

  return (
    <div className="relative group" onClick={onClick}>
      {/* Chat bubble */}
      {bubbleVisible && agent.lastMessage && (
        <div className="absolute -top-16 left-1/2 -translate-x-1/2 z-30 max-w-[200px] animate-in fade-in slide-in-from-bottom-2 duration-300">
          <div className="bg-zinc-800 border border-zinc-600 rounded-lg px-3 py-2 text-xs text-zinc-200 shadow-lg">
            <p className="line-clamp-2">{agent.lastMessage}</p>
            <div className="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 rotate-45 w-2 h-2 bg-zinc-800 border-r border-b border-zinc-600" />
          </div>
        </div>
      )}

      {/* Desk + Agent */}
      <div
        className={`
          relative w-[140px] h-[100px] rounded-lg border-2 cursor-pointer
          transition-all duration-300 overflow-visible
          ${config.bgClass} ${config.glowClass}
          ${isSelected ? "ring-2 ring-primary ring-offset-2 ring-offset-background scale-105" : rankBorder + " hover:scale-102"}
        `}
      >
        {/* Status dot */}
        <div className={`absolute top-2 right-2 w-2.5 h-2.5 rounded-full ${config.dotColor} ${agent.visualState === "working" ? "animate-pulse" : ""}`} />

        {/* Agent avatar area */}
        <div className="flex flex-col items-center justify-center h-full px-2">
          {/* Character */}
          <div className={`text-2xl ${config.animation} select-none`}>
            {agent.visualState === "sleeping" ? "😴" : agent.emoji}
          </div>

          {/* Name + Role */}
          <div className="text-center mt-1">
            <div className="text-xs font-bold text-foreground leading-tight" style={{ color: agent.color }}>
              {agent.name}
            </div>
            <div className="text-[10px] text-muted-foreground leading-tight">{agent.role}</div>
          </div>

          {/* Working indicator */}
          {agent.visualState === "working" && (
            <div className="mt-1 flex gap-0.5">
              <span className="inline-block w-1 h-1 bg-green-400 rounded-full animate-bounce" style={{ animationDelay: "0ms" }} />
              <span className="inline-block w-1 h-1 bg-green-400 rounded-full animate-bounce" style={{ animationDelay: "150ms" }} />
              <span className="inline-block w-1 h-1 bg-green-400 rounded-full animate-bounce" style={{ animationDelay: "300ms" }} />
            </div>
          )}

          {/* Streak flame */}
          {agent.streak >= 3 && (
            <div className="absolute top-1 left-1 text-xs">
              🔥{agent.streak}
            </div>
          )}

          {/* Rank crown for #1 */}
          {agent.rank === 1 && agent.score > 0 && (
            <div className="absolute -top-2 left-1/2 -translate-x-1/2 text-sm">👑</div>
          )}
        </div>

        {/* Progress bar (only when working) */}
        {agent.visualState === "working" && agent.progressPct > 0 && (
          <div className="absolute bottom-0 left-0 right-0 h-1 bg-zinc-700 rounded-b-lg overflow-hidden">
            <div
              className="h-full bg-green-500 transition-all duration-1000"
              style={{ width: `${agent.progressPct}%` }}
            />
          </div>
        )}
      </div>

      {/* Score badge */}
      <div className="absolute -bottom-3 left-1/2 -translate-x-1/2 px-2 py-0.5 rounded-full bg-zinc-800 border border-zinc-600 text-[10px] font-mono text-zinc-300 whitespace-nowrap">
        {agent.score > 0 ? `${agent.score} pts` : agent.title}
      </div>
    </div>
  );
}

// ========== COLLABORATION LINE ==========
function CollabLine({ fromId, toId, topic }: { fromId: string; toId: string; topic: string }) {
  const from = DESK_POSITIONS[fromId];
  const to = DESK_POSITIONS[toId];
  if (!from || !to) return null;

  // Approximate pixel positions based on grid
  const fx = 80 + from.x * 170;
  const fy = 60 + from.y * 140;
  const tx = 80 + to.x * 170;
  const ty = 60 + to.y * 140;

  return (
    <svg className="absolute inset-0 pointer-events-none z-10 w-full h-full overflow-visible">
      <line
        x1={fx} y1={fy} x2={tx} y2={ty}
        stroke="rgba(168, 85, 247, 0.5)"
        strokeWidth="2"
        strokeDasharray="6 4"
        className="animate-pulse"
      />
      <circle cx={(fx + tx) / 2} cy={(fy + ty) / 2} r="4" fill="rgba(168, 85, 247, 0.8)" />
    </svg>
  );
}

// ========== COMMS FEED ==========
function CommsFeed({ messages, agents }: { messages: CommMessage[]; agents: OfficeAgent[] }) {
  const feedRef = useRef<HTMLDivElement>(null);
  const agentMap = Object.fromEntries(agents.map((a) => [a.id, a]));

  useEffect(() => {
    if (feedRef.current) {
      feedRef.current.scrollTop = feedRef.current.scrollHeight;
    }
  }, [messages.length]);

  return (
    <div ref={feedRef} className="flex flex-col gap-1.5 overflow-y-auto h-full px-3 py-2 scroll-smooth">
      {messages.length === 0 && (
        <div className="text-center text-muted-foreground text-xs py-8">
          No agent comms yet. Agents will start talking when they work...
        </div>
      )}
      {messages.map((msg) => {
        const style = MSG_STYLES[msg.type] || MSG_STYLES.report;
        const fromAgent = agentMap[msg.from];
        const time = new Date(msg.timestamp).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });

        return (
          <div key={msg.id} className="flex gap-2 items-start group hover:bg-zinc-800/50 rounded px-1 py-0.5 transition-colors">
            <span className="text-sm shrink-0 mt-0.5">{style.label}</span>
            <div className="flex-1 min-w-0">
              <span className="text-xs font-semibold" style={{ color: fromAgent?.color || "#888" }}>
                {fromAgent?.name || msg.from}
              </span>
              {msg.to !== "all" && (
                <span className="text-xs text-muted-foreground">
                  {" → "}
                  <span style={{ color: agentMap[msg.to]?.color || "#888" }}>
                    {agentMap[msg.to]?.name || msg.to}
                  </span>
                </span>
              )}
              <span className="text-xs text-muted-foreground ml-1">{time}</span>
              <p className={`text-xs ${style.color} leading-snug`}>{msg.message}</p>
            </div>
          </div>
        );
      })}
    </div>
  );
}

// ========== LEADERBOARD ==========
function Leaderboard({ agents }: { agents: OfficeAgent[] }) {
  const medals = ["🥇", "🥈", "🥉"];

  return (
    <div className="flex flex-col gap-1 px-3 py-2">
      <div className="flex items-center gap-2 mb-2">
        <Trophy className="w-4 h-4 text-yellow-400" />
        <span className="text-sm font-bold text-foreground">Leaderboard</span>
      </div>
      {agents.map((agent, i) => (
        <div
          key={agent.id}
          className={`flex items-center gap-2 px-2 py-1.5 rounded transition-all ${
            i === 0 && agent.score > 0
              ? "bg-yellow-500/10 border border-yellow-500/30"
              : "hover:bg-zinc-800/50"
          }`}
        >
          <span className="text-sm w-6 text-center">
            {i < 3 && agent.score > 0 ? medals[i] : `#${i + 1}`}
          </span>
          <span className="text-xs font-semibold flex-1" style={{ color: agent.color }}>
            {agent.emoji} {agent.name}
          </span>
          <div className="text-right">
            <div className="text-xs font-mono text-foreground">{agent.score}</div>
            {agent.revenue > 0 && (
              <div className="text-[10px] text-green-400 font-mono">${agent.revenue.toFixed(2)}</div>
            )}
          </div>
          {agent.streak >= 3 && (
            <span className="text-xs">🔥</span>
          )}
        </div>
      ))}

      {/* Revenue total */}
      <div className="mt-3 pt-2 border-t border-zinc-700">
        <div className="flex justify-between text-xs">
          <span className="text-muted-foreground">Total Revenue</span>
          <span className="font-mono text-green-400">
            ${agents.reduce((sum, a) => sum + a.revenue, 0).toFixed(2)}
          </span>
        </div>
        <div className="flex justify-between text-xs mt-1">
          <span className="text-muted-foreground">Total Score</span>
          <span className="font-mono text-foreground">
            {agents.reduce((sum, a) => sum + a.score, 0)}
          </span>
        </div>
      </div>
    </div>
  );
}

// ========== AGENT DETAIL PANEL ==========
function AgentDetail({ agent, onClose }: { agent: OfficeAgent; onClose: () => void }) {
  const config = STATE_CONFIG[agent.visualState] || STATE_CONFIG.idle;

  return (
    <div className="absolute bottom-4 left-4 right-4 z-40 bg-zinc-900 border border-zinc-700 rounded-xl shadow-2xl p-4 animate-in fade-in slide-in-from-bottom-4 duration-300">
      <button onClick={onClose} className="absolute top-2 right-2 text-muted-foreground hover:text-foreground text-xs">✕</button>
      <div className="flex items-start gap-4">
        <div className="text-4xl">{agent.emoji}</div>
        <div className="flex-1">
          <div className="flex items-center gap-2">
            <h3 className="font-bold text-lg" style={{ color: agent.color }}>{agent.name}</h3>
            <span className="text-xs px-2 py-0.5 rounded-full bg-zinc-800 border border-zinc-700">{agent.role}</span>
            <span className={`text-xs px-2 py-0.5 rounded-full ${config.bgClass}`}>
              {config.icon} {config.statusText}
            </span>
          </div>
          {agent.currentTask && (
            <p className="text-sm text-muted-foreground mt-1">📋 {agent.currentTask}</p>
          )}
          <div className="flex gap-4 mt-2 text-xs">
            <span className="text-foreground font-mono">🏆 {agent.score} pts</span>
            <span className="text-green-400 font-mono">💰 ${agent.revenue.toFixed(2)}</span>
            <span className="text-foreground">🏅 {agent.title}</span>
            {agent.streak >= 3 && <span>🔥 {agent.streak} streak</span>}
          </div>
          {agent.lastMessage && (
            <div className="mt-2 text-xs text-zinc-400 italic">
              Last said: &quot;{agent.lastMessage}&quot;
            </div>
          )}
          {agent.trashTalkStyle && (
            <div className="mt-1 text-[10px] text-zinc-500">
              Trash talk style: {agent.trashTalkStyle}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

// ========== MAIN OFFICE VIEW ==========
export function AgentOffice() {
  const [data, setData] = useState<OfficeData | null>(null);
  const [selectedAgent, setSelectedAgent] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [lastCommsCount, setLastCommsCount] = useState(0);
  const [showBubbleFor, setShowBubbleFor] = useState<string | null>(null);
  const [activeTab, setActiveTab] = useState<"comms" | "leaderboard">("comms");

  const fetchData = useCallback(async () => {
    try {
      const res = await fetch("/api/office");
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();
      setData(json);
      setError(null);

      // Trigger chat bubble for newest message
      if (json.comms?.length > lastCommsCount && json.comms.length > 0) {
        const newest = json.comms[json.comms.length - 1];
        if (newest.from !== "system") {
          setShowBubbleFor(newest.from);
          setTimeout(() => setShowBubbleFor(null), 8000);
        }
      }
      setLastCommsCount(json.comms?.length || 0);
    } catch (e) {
      setError(String(e));
    }
  }, [lastCommsCount]);

  useEffect(() => {
    fetchData();
    const interval = setInterval(fetchData, 5000); // Poll every 5s
    return () => clearInterval(interval);
  }, [fetchData]);

  if (!data) {
    return (
      <div className="flex items-center justify-center h-full">
        <div className="text-center">
          <div className="text-4xl mb-4 animate-pulse">🏢</div>
          <p className="text-muted-foreground">Loading Agent Office...</p>
          {error && <p className="text-red-400 text-xs mt-2">{error}</p>}
        </div>
      </div>
    );
  }

  const agentMap = Object.fromEntries(data.agents.map((a) => [a.id, a]));
  const selected = selectedAgent ? agentMap[selectedAgent] : null;

  // Stats
  const workingCount = data.agents.filter((a) => a.visualState === "working").length;
  const collabCount = data.collaborations.length;
  const totalScore = data.agents.reduce((s, a) => s + a.score, 0);

  return (
    <div className="flex h-full w-full overflow-hidden">
      {/* ===== MAIN OFFICE AREA ===== */}
      <div className="flex-1 flex flex-col min-w-0">
        {/* Header bar */}
        <div className="flex items-center justify-between px-4 py-2 border-b border-border bg-card/50">
          <div className="flex items-center gap-3">
            <span className="text-lg">🏢</span>
            <h2 className="font-bold text-foreground">Agent Office</h2>
            <div className="flex items-center gap-1 text-xs text-green-400">
              <div className="w-2 h-2 rounded-full bg-green-400 animate-pulse" />
              Live
            </div>
          </div>
          <div className="flex items-center gap-4 text-xs text-muted-foreground">
            <span className="flex items-center gap-1">
              <Zap className="w-3 h-3 text-green-400" />
              {workingCount} working
            </span>
            <span className="flex items-center gap-1">
              <Users className="w-3 h-3 text-purple-400" />
              {collabCount} collab{collabCount !== 1 ? "s" : ""}
            </span>
            <span className="flex items-center gap-1">
              <Trophy className="w-3 h-3 text-yellow-400" />
              {totalScore} pts
            </span>
          </div>
        </div>

        {/* Office floor */}
        <div className="flex-1 relative overflow-auto p-6">
          {/* Collaboration lines */}
          {data.collaborations.map((c, i) => (
            <CollabLine key={i} fromId={c.agents[0]} toId={c.agents[1]} topic={c.topic} />
          ))}

          {/* ===== MINI ORG CHART ===== */}
          <div className="flex justify-center mb-6">
            <div className="flex flex-col items-center gap-1">
              {/* Rut (team lead) */}
              <div className="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gradient-to-r from-amber-500/20 to-yellow-500/20 border border-yellow-500/40 shadow-[0_0_12px_rgba(250,204,21,0.15)]">
                <span className="text-sm">👔</span>
                <span className="text-xs font-bold text-yellow-400">Rut</span>
              </div>
              {/* Connector */}
              <div className="w-px h-3 bg-zinc-600" />
              {/* Rio node */}
              <div className="flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-pink-500/10 border border-pink-500/30">
                <span className="text-xs">📋</span>
                <span className="text-[10px] font-semibold text-pink-400">Rio · Chief of Staff</span>
              </div>
              {/* Connector branches */}
              <div className="w-px h-2 bg-zinc-600" />
              <div className="flex items-center gap-0">
                <div className="w-[80px] h-px bg-zinc-600" />
                <div className="w-2 h-2 rounded-full bg-zinc-600" />
                <div className="w-[80px] h-px bg-zinc-600" />
              </div>
              {/* Exec trio */}
              <div className="flex items-center gap-6 -mt-1">
                <div className="flex flex-col items-center">
                  <div className="w-px h-2 bg-zinc-600" />
                  <div className="flex items-center gap-1 px-2 py-0.5 rounded-md bg-cyan-500/10 border border-cyan-500/30">
                    <span className="text-[10px] font-semibold text-cyan-400">⚡ Rip · COO</span>
                  </div>
                </div>
                <div className="flex flex-col items-center">
                  <div className="w-px h-2 bg-zinc-600" />
                  <div className="flex items-center gap-1 px-2 py-0.5 rounded-md bg-blue-500/10 border border-blue-500/30">
                    <span className="text-[10px] font-semibold text-blue-400">🔧 Rex · CTO</span>
                  </div>
                </div>
                <div className="flex flex-col items-center">
                  <div className="w-px h-2 bg-zinc-600" />
                  <div className="flex items-center gap-1 px-2 py-0.5 rounded-md bg-green-500/10 border border-green-500/30">
                    <span className="text-[10px] font-semibold text-green-400">💰 Red · CFO</span>
                  </div>
                </div>
              </div>
              {/* Bottom connector to workers */}
              <div className="flex items-center gap-0 mt-1">
                <div className="text-[9px] text-zinc-500 font-mono">Ria · Rea · Reg · Rak · Worker</div>
              </div>
            </div>
          </div>

          {/* Desk grid */}
          <div className="ml-2">
            {/* ===== EXEC COUNCIL - HIGHLIGHTED ===== */}
            <div className="relative mb-6">
              <div className="absolute -inset-3 rounded-xl bg-gradient-to-r from-yellow-500/5 via-amber-500/8 to-yellow-500/5 border border-yellow-500/20 shadow-[0_0_20px_rgba(250,204,21,0.08)]" />
              <div className="relative">
                <div className="flex items-center gap-2 mb-3 ml-1">
                  <Crown className="w-4 h-4 text-yellow-400" />
                  <span className="text-[11px] font-bold text-yellow-400/90 tracking-wider uppercase">Exec Council</span>
                  <div className="flex-1 h-px bg-gradient-to-r from-yellow-500/30 to-transparent" />
                  <span className="text-[9px] text-yellow-500/50 font-mono">Rip has FINAL CALL</span>
                </div>
                <div className="flex gap-6 ml-1">
                  {["rip", "rex", "red"].map((id) => {
                    const agent = agentMap[id];
                    return agent ? (
                      <AgentDesk
                        key={id}
                        agent={agent}
                        isSelected={selectedAgent === id}
                        onClick={() => setSelectedAgent(selectedAgent === id ? null : id)}
                        showBubble={showBubbleFor === id}
                      />
                    ) : null;
                  })}
                </div>
              </div>
            </div>

            {/* ===== STAFF ===== */}
            <div className="relative mb-6 mt-8">
              <div className="flex items-center gap-2 mb-3 ml-1">
                <Coffee className="w-3.5 h-3.5 text-pink-400/70" />
                <span className="text-[10px] font-semibold text-muted-foreground tracking-wider uppercase">Staff</span>
                <div className="flex-1 h-px bg-zinc-700/50" />
              </div>
              <div className="flex gap-6 ml-1">
                {["rio", "ria", "rea"].map((id) => {
                  const agent = agentMap[id];
                  return agent ? (
                    <AgentDesk
                      key={id}
                      agent={agent}
                      isSelected={selectedAgent === id}
                      onClick={() => setSelectedAgent(selectedAgent === id ? null : id)}
                      showBubble={showBubbleFor === id}
                    />
                  ) : null;
                })}
              </div>
            </div>

            {/* ===== ENGINEERS ===== */}
            <div className="relative mb-6">
              <div className="flex items-center gap-2 mb-3 ml-1">
                <Zap className="w-3.5 h-3.5 text-emerald-400/70" />
                <span className="text-[10px] font-semibold text-muted-foreground tracking-wider uppercase">Engineers</span>
                <div className="flex-1 h-px bg-zinc-700/50" />
              </div>
              <div className="flex gap-6 ml-1">
                {["reg", "rak", "worker"].map((id) => {
                  const agent = agentMap[id];
                  return agent ? (
                    <AgentDesk
                      key={id}
                      agent={agent}
                      isSelected={selectedAgent === id}
                      onClick={() => setSelectedAgent(selectedAgent === id ? null : id)}
                      showBubble={showBubbleFor === id}
                    />
                  ) : null;
                })}
              </div>
            </div>
          </div>

          {/* Legend */}
          <div className="absolute bottom-4 left-4 flex gap-3 text-[10px] text-muted-foreground">
            {Object.entries(STATE_CONFIG).map(([key, val]) => (
              <span key={key} className="flex items-center gap-1">
                <span className={`w-2 h-2 rounded-full ${val.dotColor}`} />
                {val.statusText}
              </span>
            ))}
          </div>

          {/* Agent detail panel */}
          {selected && (
            <AgentDetail agent={selected} onClose={() => setSelectedAgent(null)} />
          )}
        </div>
      </div>

      {/* ===== SIDEBAR: Comms + Leaderboard ===== */}
      <div className="w-80 border-l border-border bg-card/50 flex flex-col shrink-0">
        {/* Tab switcher */}
        <div className="flex border-b border-border">
          <button
            onClick={() => setActiveTab("comms")}
            className={`flex-1 flex items-center justify-center gap-1.5 py-2.5 text-xs font-medium transition-colors ${
              activeTab === "comms"
                ? "text-primary border-b-2 border-primary"
                : "text-muted-foreground hover:text-foreground"
            }`}
          >
            <MessageSquare className="w-3.5 h-3.5" />
            Comms
            {data.comms.length > 0 && (
              <span className="ml-1 px-1.5 py-0.5 rounded-full bg-primary/20 text-primary text-[10px]">
                {data.comms.length}
              </span>
            )}
          </button>
          <button
            onClick={() => setActiveTab("leaderboard")}
            className={`flex-1 flex items-center justify-center gap-1.5 py-2.5 text-xs font-medium transition-colors ${
              activeTab === "leaderboard"
                ? "text-primary border-b-2 border-primary"
                : "text-muted-foreground hover:text-foreground"
            }`}
          >
            <Trophy className="w-3.5 h-3.5" />
            Leaderboard
          </button>
        </div>

        {/* Tab content */}
        <div className="flex-1 overflow-hidden">
          {activeTab === "comms" ? (
            <CommsFeed messages={data.comms} agents={data.agents} />
          ) : (
            <Leaderboard agents={data.leaderboard} />
          )}
        </div>
      </div>
    </div>
  );
}
