"use client";

import { useState, useEffect, useCallback } from "react";
import {
  DollarSign,
  TrendingUp,
  TrendingDown,
  Activity,
  Bot,
  Rocket,
  Clock,
  AlertTriangle,
  CheckCircle2,
  XCircle,
  BarChart3,
  RefreshCw,
  Loader2,
  Wallet,
  Zap,
  MessageSquare,
  GitBranch,
  Calendar,
  ArrowUpRight,
  ArrowDownRight,
  Minus,
} from "lucide-react";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { ScrollArea } from "@/components/ui/scroll-area";

// Types
interface AgentStatus {
  id: string;
  name: string;
  status: "active" | "idle" | "error";
  model?: string;
  lastActivity?: string;
  tokenUsage?: number;
  cost?: number;
}

interface RevenueMetric {
  source: string;
  today: number;
  trend: "up" | "down" | "flat";
  change: number;
}

interface CostMetric {
  provider: string;
  model: string;
  cost: number;
  tokens: number;
  requests: number;
}

interface KalshiPosition {
  ticker: string;
  contracts: number;
  avgPrice: number;
  currentPrice: number;
  pnl: number;
}

interface ActivityItem {
  id: string;
  type: string;
  agent: string;
  message: string;
  time: string;
}

// Stat Card Component
function StatCard({
  title,
  value,
  subtitle,
  icon: Icon,
  trend,
  accentColor,
  onClick,
}: {
  title: string;
  value: string;
  subtitle?: string;
  icon: React.ComponentType<{ className?: string }>;
  trend?: "up" | "down" | "flat";
  accentColor?: string;
  onClick?: () => void;
}) {
  return (
    <div 
      className={`glass-panel rounded-lg p-5 ${onClick ? "cursor-pointer hover:ring-2 hover:ring-primary/50 transition-all" : ""}`}
      onClick={onClick}
    >
      <div className="flex items-center justify-between mb-3">
        <span className="text-xs font-bold uppercase tracking-wider text-muted-foreground">
          {title}
        </span>
        <div
          className={`w-8 h-8 rounded flex items-center justify-center ${
            accentColor || "bg-primary/10"
          }`}
        >
          <Icon className={`w-4 h-4 ${accentColor ? "text-white" : "text-primary"}`} />
        </div>
      </div>
      <div className="text-2xl font-bold font-mono">{value}</div>
      {subtitle && (
        <div className="flex items-center gap-1.5 mt-1 text-xs text-muted-foreground">
          {trend === "up" && <TrendingUp className="w-3.5 h-3.5 text-green-500" />}
          {trend === "down" && <TrendingDown className="w-3.5 h-3.5 text-red-400" />}
          {trend === "flat" && <Minus className="w-3.5 h-3.5" />}
          <span>{subtitle}</span>
        </div>
      )}
    </div>
  );
}

// Agent Status Card
function AgentCard({ agent }: { agent: AgentStatus }) {
  const statusColors = {
    active: "bg-green-500",
    idle: "bg-yellow-500",
    error: "bg-red-500",
  };

  return (
    <div className="flex items-center gap-3 p-3 rounded-lg bg-muted/30 border border-border">
      <div className="relative">
        <Bot className="w-8 h-8 text-primary" />
        <div
          className={`absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-background ${
            statusColors[agent.status]
          }`}
        />
      </div>
      <div className="flex-1 min-w-0">
        <div className="font-medium text-sm">{agent.name}</div>
        <div className="text-xs text-muted-foreground truncate">
          {agent.model || "No model"}
        </div>
      </div>
      <div className="text-right">
        <div className="text-xs font-mono">${(agent.cost || 0).toFixed(2)}</div>
        <div className="text-xs text-muted-foreground">
          {formatNumber(agent.tokenUsage || 0)} tokens
        </div>
      </div>
    </div>
  );
}

// Activity Feed Item
function ActivityItem({ item }: { item: ActivityItem }) {
  const iconMap: Record<string, React.ComponentType<{ className?: string }>> = {
    task_completed: CheckCircle2,
    task_started: Activity,
    error: AlertTriangle,
    message: MessageSquare,
    trade: DollarSign,
    deploy: Rocket,
  };
  const Icon = iconMap[item.type] || Activity;

  return (
    <div className="flex items-start gap-3 py-2">
      <div className="w-6 h-6 rounded-full bg-muted/50 flex items-center justify-center flex-shrink-0">
        <Icon className="w-3 h-3 text-muted-foreground" />
      </div>
      <div className="flex-1 min-w-0">
        <p className="text-sm">{item.message}</p>
        <div className="flex items-center gap-2 mt-0.5 text-xs text-muted-foreground">
          <span>{item.agent}</span>
          <span>•</span>
          <span>{item.time}</span>
        </div>
      </div>
    </div>
  );
}

function formatNumber(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return n.toString();
}

function formatTime(dateStr: string): string {
  const date = new Date(dateStr);
  const now = new Date();
  const diff = now.getTime() - date.getTime();

  if (diff < 60000) return "just now";
  if (diff < 3600000) return `${Math.floor(diff / 60000)}m ago`;
  if (diff < 86400000) return `${Math.floor(diff / 3600000)}h ago`;
  return date.toLocaleDateString();
}

// View types for navigation (matching page.tsx)
type ViewId = "overview" | "office" | "board" | "agents" | "missions" | "workflows" | "knowledge" | "tools" | "usage" | "finance" | "models" | "approvals" | "cron" | "logs" | "settings" | "chat";

// Main CEO Dashboard
export function CEODashboard({ onNavigate }: { onNavigate?: (view: ViewId) => void }) {
  const [loading, setLoading] = useState(true);
  const [agents, setAgents] = useState<AgentStatus[]>([]);
  const [costs, setCosts] = useState<CostMetric[]>([]);
  const [kalshi, setKalshi] = useState<{ balance: number; positions: KalshiPosition[] } | null>(
    null
  );
  const [activities, setActivities] = useState<ActivityItem[]>([]);
  const [totalRevenue, setTotalRevenue] = useState(0);
  const [totalCost, setTotalCost] = useState(0);

  const fetchData = useCallback(async () => {
    try {
      // Fetch all data in parallel
      const [agentsRes, costsRes, kalshiRes, statusRes] = await Promise.allSettled([
        fetch("/api/openclaw/status"),
        fetch("/api/costs?period=today"),
        fetch("/api/kalshi?action=overview"),
        fetch("/api/dashboard/status"),
      ]);

      // Process agents
      if (agentsRes.status === "fulfilled") {
        const agentsData = await agentsRes.value.json();
        if (agentsData.sessions) {
          const agentList: AgentStatus[] = [];
          for (const [key, session] of Object.entries(agentsData.sessions || {})) {
            const s = session as any;
            agentList.push({
              id: key,
              name: s.name || key.split(":").pop() || key,
              status: s.status === "idle" ? "idle" : s.active ? "active" : "idle",
              model: s.model,
              lastActivity: s.lastActivity,
              tokenUsage: s.tokens || 0,
              cost: s.cost || 0,
            });
          }
          setAgents(agentList);
        }
      }

      // Process costs
      if (costsRes.status === "fulfilled") {
        const costsData = await costsRes.value.json();
        if (costsData.breakdown) {
          setCosts(costsData.breakdown);
          setTotalCost(costsData.totalCost || 0);
        }
      }

      // Process Kalshi
      if (kalshiRes.status === "fulfilled") {
        const kalshiData = await kalshiRes.value.json();
        if (kalshiData.balance) {
          setKalshi({
            balance: kalshiData.balance.availableBalance || 0,
            positions: kalshiData.positions || [],
          });
        }
      }

      // Process dashboard status for activities
      if (statusRes.status === "fulfilled") {
        const statusData = await statusRes.value.json();
        if (statusData.activities) {
          setActivities(
            statusData.activities.slice(0, 10).map((a: any) => ({
              id: a.id,
              type: a.type,
              agent: a.agent_id || "system",
              message: a.message,
              time: formatTime(a.created_at),
            }))
          );
        }
      }
    } catch (err) {
      console.error("Failed to fetch dashboard data:", err);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchData();
    const interval = setInterval(fetchData, 30000); // Refresh every 30s
    return () => clearInterval(interval);
  }, [fetchData]);

  const netProfit = totalRevenue - totalCost;
  const kalshiPnL = kalshi?.positions.reduce((sum, p) => sum + p.pnl, 0) || 0;

  if (loading) {
    return (
      <div className="flex-1 flex items-center justify-center">
        <Loader2 className="w-8 h-8 animate-spin text-primary" />
      </div>
    );
  }

  return (
    <div className="flex-1 overflow-auto min-h-0 p-4 space-y-4">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold">Rut's Home</h1>
          <p className="text-sm text-muted-foreground">
            Real-time overview of RutRoh operations
          </p>
        </div>
        <Button variant="outline" onClick={fetchData} className="gap-2">
          <RefreshCw className={`w-4 h-4 ${loading ? "animate-spin" : ""}`} />
          Refresh
        </Button>
      </div>

      {/* Key Metrics */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <StatCard
          title="Today's Revenue"
          value={`$${totalRevenue.toFixed(2)}`}
          subtitle="From all sources"
          icon={DollarSign}
          trend={totalRevenue > 0 ? "up" : "flat"}
          accentColor="bg-green-500"
          onClick={() => onNavigate?.("finance")}
        />
        <StatCard
          title="API Costs"
          value={`$${totalCost.toFixed(2)}`}
          subtitle={`${costs.length} providers`}
          icon={Zap}
          trend={totalCost > 10 ? "down" : "flat"}
          accentColor="bg-orange-500"
          onClick={() => onNavigate?.("usage")}
        />
        <StatCard
          title="Net Profit"
          value={`$${netProfit.toFixed(2)}`}
          subtitle={netProfit >= 0 ? "Profitable" : "Loss"}
          icon={BarChart3}
          trend={netProfit >= 0 ? "up" : "down"}
          accentColor={netProfit >= 0 ? "bg-blue-500" : "bg-red-500"}
          onClick={() => onNavigate?.("finance")}
        />
        <StatCard
          title="Kalshi Balance"
          value={`$${(kalshi?.balance || 0).toFixed(2)}`}
          subtitle={`P&L: ${kalshiPnL >= 0 ? "+" : ""}$${kalshiPnL.toFixed(2)}`}
          icon={Wallet}
          trend={kalshiPnL >= 0 ? "up" : "down"}
          accentColor="bg-purple-500"
          onClick={() => onNavigate?.("finance")}
        />
      </div>

      {/* Main Content Grid */}
      <div className="grid grid-cols-3 gap-6">
        {/* Left Column: Agents */}
        <div className="col-span-1 space-y-4">
          <div 
            className="flex items-center justify-between cursor-pointer hover:text-primary transition-colors"
            onClick={() => onNavigate?.("office")}
          >
            <h2 className="font-semibold flex items-center gap-2">
              <Bot className="w-4 h-4" />
              Active Agents
            </h2>
            <Badge variant="secondary">
              {agents.filter((a) => a.status === "active").length} active
            </Badge>
          </div>
          <div className="space-y-2">
            {agents.length > 0 ? (
              agents.map((agent) => <AgentCard key={agent.id} agent={agent} />)
            ) : (
              <p className="text-sm text-muted-foreground text-center py-4">
                No active agents
              </p>
            )}
          </div>
        </div>

        {/* Center Column: Cost Breakdown */}
        <div className="col-span-1 space-y-4">
          <div 
            className="flex items-center justify-between cursor-pointer hover:text-primary transition-colors"
            onClick={() => onNavigate?.("usage")}
          >
            <h2 className="font-semibold flex items-center gap-2">
              <Zap className="w-4 h-4" />
              Cost Breakdown
            </h2>
            <Badge variant="secondary">${totalCost.toFixed(2)} today</Badge>
          </div>
          <div className="space-y-2">
            {costs.length > 0 ? (
              costs.slice(0, 6).map((cost, i) => (
                <div
                  key={i}
                  className="flex items-center justify-between p-3 rounded-lg bg-muted/30 border border-border"
                >
                  <div>
                    <div className="text-sm font-medium">{cost.model.split("/").pop()}</div>
                    <div className="text-xs text-muted-foreground">
                      {cost.provider} • {formatNumber(cost.tokens)} tokens
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-sm font-mono">${cost.cost.toFixed(2)}</div>
                    <div className="text-xs text-muted-foreground">
                      {cost.requests} requests
                    </div>
                  </div>
                </div>
              ))
            ) : (
              <p className="text-sm text-muted-foreground text-center py-4">
                No cost data available
              </p>
            )}
          </div>
        </div>

        {/* Right Column: Activity Feed */}
        <div className="col-span-1 space-y-4">
          <div 
            className="flex items-center justify-between cursor-pointer hover:text-primary transition-colors"
            onClick={() => onNavigate?.("logs")}
          >
            <h2 className="font-semibold flex items-center gap-2">
              <Activity className="w-4 h-4" />
              Recent Activity
            </h2>
            <Badge variant="secondary">{activities.length} items</Badge>
          </div>
          <ScrollArea className="h-[300px]">
            <div className="divide-y divide-border">
              {activities.length > 0 ? (
                activities.map((item) => (
                  <ActivityItem key={item.id} item={item} />
                ))
              ) : (
                <p className="text-sm text-muted-foreground text-center py-4">
                  No recent activity
                </p>
              )}
            </div>
          </ScrollArea>
        </div>
      </div>

      {/* Kalshi Positions */}
      {kalshi && kalshi.positions.length > 0 && (
        <div className="space-y-4">
          <h2 className="font-semibold flex items-center gap-2">
            <GitBranch className="w-4 h-4" />
            Kalshi Positions
          </h2>
          <div className="grid grid-cols-2 lg:grid-cols-4 gap-3">
            {kalshi.positions.map((pos, i) => (
              <div
                key={i}
                className="p-4 rounded-lg bg-muted/30 border border-border"
              >
                <div className="font-medium text-sm truncate">{pos.ticker}</div>
                <div className="text-xs text-muted-foreground mt-1">
                  {pos.contracts} contracts @ ${(pos.avgPrice ?? 0).toFixed(2)}
                </div>
                <div
                  className={`text-lg font-mono mt-2 ${
                    (pos.pnl ?? 0) >= 0 ? "text-green-500" : "text-red-500"
                  }`}
                >
                  {(pos.pnl ?? 0) >= 0 ? "+" : ""}${(pos.pnl ?? 0).toFixed(2)}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Quick Actions */}
      <div className="flex items-center gap-4 pt-4 border-t border-border">
        <Button variant="outline" className="gap-2" onClick={() => onNavigate?.("cron")}>
          <Calendar className="w-4 h-4" />
          View Cron Jobs
        </Button>
        <Button variant="outline" className="gap-2" onClick={() => onNavigate?.("missions")}>
          <Rocket className="w-4 h-4" />
          View Missions
        </Button>
        <Button variant="outline" className="gap-2" onClick={() => onNavigate?.("chat")}>
          <MessageSquare className="w-4 h-4" />
          Open Chat
        </Button>
      </div>
    </div>
  );
}
